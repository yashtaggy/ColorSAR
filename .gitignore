# ==========================================
# ColorSAR - Project Git Ignore
# ==========================================

# --- Node.js / Frontend ---
**/node_modules/
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/
frontend/.vercel/
frontend/.env*.local

# --- Python / Backend ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
backend/build/
backend/dist/
backend/*.egg-info/
backend/weights/*.pth
backend/weights/*.pt

# --- Environment & Secrets (CRITICAL SECURITY) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/*serviceAccountKey.json
**/firebase-key.json
*.pem
*.key

# --- Machine Learning & Large Files ---
# Ignore large model weights (100MB+ files fail GitHub push)
backend/weights/
*.pth
*.pt
*.h5
*.onnx
*.weights
*.pkl
*.joblib

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- Build Archives & Logs ---
*.log
*.tmp
*.bak
v_2/
old_version/
temp_input.png

# --- IDEs & System ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Vercel ---
.vercel/

